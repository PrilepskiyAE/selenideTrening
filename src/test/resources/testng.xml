<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- Главный блок TestNG: описывает набор тестов -->
<suite name="Test Suite">

    <!-- Один логический запуск (можно добавить несколько тестов внутри одной suite) -->
    <test name="selenideTest">

        <!-- Указываем, какие именно тестовые классы запускать -->
        <classes>
            <!-- Тест авторизации -->
            <class name="demoqaTest.DemoQaTest"/>

            <!-- Тест подсчёта суммы в корзине -->
            <class name="selenideTest.AppleTest"/>
        </classes>

    </test>

    <test name="RestTest">
        <classes>
             <class name="fakestoreapi.FakestoreapiTest"/>
        </classes>
    </test>

</suite>